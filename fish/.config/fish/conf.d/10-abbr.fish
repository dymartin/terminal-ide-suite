# Abbreviations expand inline (you see the full command) — better than aliases.
status is-interactive; or exit

abbr -a g   git
abbr -a lg  lazygit
abbr -a y   yazi
abbr -a j   just
abbr -a c   claude
abbr -a oc  opencode
abbr -a v   hx
abbr -a ls  eza
abbr -a ll  'eza -la --git --icons'
abbr -a lt  'eza --tree --level=2 --icons'
abbr -a cat bat
abbr -a rgi 'rg -i'

# git shortcuts
abbr -a gs  'git status -sb'
abbr -a gd  'git diff'
abbr -a gl  'git log --oneline --graph --decorate -20'
abbr -a gco 'git checkout'
abbr -a gb  'git branch'
